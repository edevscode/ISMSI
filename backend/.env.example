# Copy this file to .env and fill in the correct values.
# Never commit .env to version control.

# Django
# Generate with: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=your-secret-key-here
DEBUG=True

# MySQL — must match your local MySQL instance
DATABASE_NAME=ismsi_db
DATABASE_USER=root
DATABASE_PASSWORD=your-db-password
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306

# Cloudinary (for media/image uploads)
# Sign up at https://cloudinary.com and copy your API URL from the dashboard
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Admin seed account (used by create_admin.py — override via CLI flags instead if preferred)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Administrator
ADMIN_PHONE=09000000000
